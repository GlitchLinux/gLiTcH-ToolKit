set -euo pipefail

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Globals ─────────────────────────────────────────────────
REMOTE_HOST=""
REMOTE_PORT="22"
REMOTE_USER=""
REMOTE_PASS=""
VNC_DISPLAY=":1"
VNC_PORT="5901"
VNC_RESOLUTION="1920x1080"
VNC_DEPTH="24"
VNC_PASS=""
USE_TUNNEL=true
LOCAL_PORT=""
KILL_SESSION=false
VERBOSE=false
DRY_RUN=false
VIEWER_ONLY=false

# ── Helpers ─────────────────────────────────────────────────
info()  { echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok()    { echo -e "${GREEN}[  OK]${RESET}  $*"; }
warn()  { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
fail()  { echo -e "${RED}[FAIL]${RESET}  $*"; }
die()   { fail "$*"; exit 1; }

banner() {
    echo ""
    echo -e "${BOLD}${MAGENTA}╔═══════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${MAGENTA}║   vncforward  ─  TigerVNC Remote Desktop ║${RESET}"
    echo -e "${BOLD}${MAGENTA}╚═══════════════════════════════════════════╝${RESET}"
    echo ""
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Options:
  -h, --host HOST       Remote SSH host (IP or hostname)
  -p, --port PORT       Remote SSH port (default: 22)
  -u, --user USER       Remote SSH username
  -w, --pass PASS       Remote SSH password
  -d, --display DISP    VNC display number (default: :1)
  -r, --resolution RES  VNC resolution (default: 1920x1080)
  --depth DEPTH         Color depth 16/24/32 (default: 24)
  --vnc-pass PASS       VNC session password (default: prompted)
  --tunnel              Use SSH tunnel (default)
  --direct              Connect directly (no tunnel, VNC port must be open)
  --local-port PORT     Local port for SSH tunnel (default: auto)
  --viewer-only         Skip setup, just connect viewer
  --kill                Kill remote VNC session and exit
  -n, --dry-run         Check everything but don't connect
  -v, --verbose         Verbose output
  --help                Show this help

Examples:
  $(basename "$0")                                      # Interactive mode
  $(basename "$0") -h 192.168.0.50 -u x                # Prompted for passwords
  $(basename "$0") -h server.com -u root --direct       # Direct VNC (no tunnel)
  $(basename "$0") -h server.com -u root --kill         # Kill remote VNC session
  $(basename "$0") --viewer-only -h server.com -u x     # Skip setup, just view

EOF
    exit 0
}

# ── Argument parsing ────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--host)       REMOTE_HOST="$2"; shift 2 ;;
            -p|--port)       REMOTE_PORT="$2"; shift 2 ;;
            -u|--user)       REMOTE_USER="$2"; shift 2 ;;
            -w|--pass)       REMOTE_PASS="$2"; shift 2 ;;
            -d|--display)    VNC_DISPLAY="$2"; shift 2 ;;
            -r|--resolution) VNC_RESOLUTION="$2"; shift 2 ;;
            --depth)         VNC_DEPTH="$2"; shift 2 ;;
            --vnc-pass)      VNC_PASS="$2"; shift 2 ;;
            --tunnel)        USE_TUNNEL=true; shift ;;
            --direct)        USE_TUNNEL=false; shift ;;
            --local-port)    LOCAL_PORT="$2"; shift 2 ;;
            --viewer-only)   VIEWER_ONLY=true; shift ;;
            --kill)          KILL_SESSION=true; shift ;;
            -n|--dry-run)    DRY_RUN=true; shift ;;
            -v|--verbose)    VERBOSE=true; shift ;;
            --help)          usage ;;
            *)               die "Unknown option: $1" ;;
        esac
    done

    # Derive VNC port from display number
    local disp_num="${VNC_DISPLAY#:}"
    VNC_PORT=$((5900 + disp_num))

    # Auto-assign local tunnel port
    if [[ -z "$LOCAL_PORT" ]]; then
        LOCAL_PORT="$VNC_PORT"
    fi
}

# ── Interactive credential prompt ───────────────────────────
prompt_credentials() {
    echo -e "${BOLD}─── Target VNC Host Credentials ───${RESET}"
    echo ""

    if [[ -z "$REMOTE_HOST" ]]; then
        read -rp "  Host (IP or hostname): " REMOTE_HOST
        [[ -z "$REMOTE_HOST" ]] && die "Host cannot be empty."
    else
        echo -e "  Host: ${GREEN}${REMOTE_HOST}${RESET}"
    fi

    if [[ "$REMOTE_PORT" == "22" ]]; then
        read -rp "  SSH Port [22]: " input_port
        REMOTE_PORT="${input_port:-22}"
    else
        echo -e "  Port: ${GREEN}${REMOTE_PORT}${RESET}"
    fi

    if [[ -z "$REMOTE_USER" ]]; then
        read -rp "  Username: " REMOTE_USER
        [[ -z "$REMOTE_USER" ]] && die "Username cannot be empty."
    else
        echo -e "  User: ${GREEN}${REMOTE_USER}${RESET}"
    fi

    if [[ -z "$REMOTE_PASS" ]]; then
        read -rsp "  SSH Password: " REMOTE_PASS
        echo ""
        [[ -z "$REMOTE_PASS" ]] && die "SSH password cannot be empty."
    else
        echo -e "  SSH Pass: ${DIM}(provided via flag)${RESET}"
    fi

    echo ""

    # Connection mode
    if ! $KILL_SESSION && ! $VIEWER_ONLY; then
        echo -e "${BOLD}─── Connection Mode ───${RESET}"
        echo ""
        echo -e "  ${CYAN}1)${RESET} SSH Tunnel ${DIM}(secure, recommended — VNC port stays closed)${RESET}"
        echo -e "  ${CYAN}2)${RESET} Direct     ${DIM}(requires VNC port open in firewall)${RESET}"
        echo ""
        read -rp "  Choose [1]: " mode_choice
        case "${mode_choice:-1}" in
            2) USE_TUNNEL=false ;;
            *) USE_TUNNEL=true ;;
        esac
        echo ""
    fi

    # VNC password
    if ! $KILL_SESSION; then
        if [[ -z "$VNC_PASS" ]]; then
            read -rsp "  VNC Password (for viewer auth) [default: use SSH pass]: " VNC_PASS
            echo ""
            VNC_PASS="${VNC_PASS:-$REMOTE_PASS}"
        else
            echo -e "  VNC Pass: ${DIM}(provided via flag)${RESET}"
        fi
    fi

    echo ""
}

# ── SSH helper ──────────────────────────────────────────────
remote_exec() {
    sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -o ConnectTimeout=10 -p "$REMOTE_PORT" \
        "$REMOTE_USER@$REMOTE_HOST" "$@" 2>/dev/null
}

remote_exec_stdin() {
    sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -o ConnectTimeout=10 -p "$REMOTE_PORT" \
        "$REMOTE_USER@$REMOTE_HOST" bash 2>/dev/null
}

# ── Local dependency checks ─────────────────────────────────
check_local_deps() {
    info "Checking local dependencies..."
    local missing=()

    # sshpass
    if command -v sshpass &>/dev/null; then
        ok "sshpass found"
    else
        missing+=("sshpass")
        fail "sshpass not found"
    fi

    # ssh
    if command -v ssh &>/dev/null; then
        ok "ssh found"
    else
        missing+=("openssh-client")
        fail "ssh not found"
    fi

    # VNC viewer — check multiple known binaries
    local viewer_found=false
    for v in xtigervncviewer vncviewer xvnc4viewer; do
        if command -v "$v" &>/dev/null; then
            ok "VNC viewer found: $v"
            viewer_found=true
            break
        fi
    done
    if ! $viewer_found; then
        missing+=("tigervnc-viewer")
        fail "No VNC viewer found"
    fi

    # Install missing
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo ""
        warn "Missing packages: ${missing[*]}"
        read -rp "  Install missing packages? [Y/n]: " install_confirm
        if [[ "${install_confirm,,}" != "n" ]]; then
            info "Installing: ${missing[*]}..."
            if command -v apt-get &>/dev/null; then
                sudo apt-get update -qq && sudo apt-get install -y -qq "${missing[@]}"
            elif command -v dnf &>/dev/null; then
                sudo dnf install -y "${missing[@]}"
            elif command -v pacman &>/dev/null; then
                sudo pacman -S --noconfirm "${missing[@]}"
            else
                die "Unknown package manager. Install manually: ${missing[*]}"
            fi
            ok "Packages installed."
        else
            die "Cannot proceed without: ${missing[*]}"
        fi
    fi

    echo ""
}

# ── Test SSH connectivity ───────────────────────────────────
test_connection() {
    info "Testing SSH connectivity to ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PORT}..."
    if ! remote_exec "echo CONNECTION_OK" | grep -q "CONNECTION_OK"; then
        die "Cannot connect. Check credentials and network."
    fi
    ok "SSH connection successful."
    echo ""
}

# ── Install TigerVNC on remote ──────────────────────────────
install_remote_vnc() {
    info "Checking remote TigerVNC installation..."

    local vnc_status
    vnc_status=$(remote_exec "command -v vncserver 2>/dev/null && echo VNC_FOUND || echo VNC_MISSING")

    if [[ "$vnc_status" == *"VNC_FOUND"* ]]; then
        ok "TigerVNC server already installed on remote."
    else
        warn "TigerVNC server not found on remote. Installing..."
        local install_result
        install_result=$(remote_exec_stdin <<'INSTALLSCRIPT'
if command -v apt-get &>/dev/null; then
    sudo apt-get update -qq
    sudo apt-get install -y -qq tigervnc-standalone-server tigervnc-common tigervnc-tools 2>/dev/null \
        || sudo apt-get install -y -qq tigervnc-standalone-server tigervnc-common 2>/dev/null
    echo "INSTALL_DONE"
elif command -v dnf &>/dev/null; then
    sudo dnf install -y tigervnc-server
    echo "INSTALL_DONE"
elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm tigervnc
    echo "INSTALL_DONE"
else
    echo "INSTALL_FAIL"
fi
INSTALLSCRIPT
        )
        if [[ "$install_result" == *"INSTALL_DONE"* ]]; then
            ok "TigerVNC server installed on remote."
        else
            die "Could not install TigerVNC on remote. Install manually: sudo apt install tigervnc-standalone-server"
        fi
    fi

    # Also ensure dbus-x11 is available (needed by many DEs)
    remote_exec "command -v dbus-launch &>/dev/null || (sudo apt-get install -y -qq dbus-x11 2>/dev/null || true)" &>/dev/null

    echo ""
}

# ── Detect remote desktop environment ───────────────────────
detect_remote_de() {
    info "Auto-detecting desktop environment on remote..."

    local de_result
    de_result=$(remote_exec_stdin <<'DETECTSCRIPT'
# Priority order: XFCE > KDE > GNOME > LXDE > LXQT > MATE > Cinnamon > i3 > openbox > twm
DE_CMD=""
DE_NAME=""

if command -v startxfce4 &>/dev/null; then
    DE_CMD="startxfce4"
    DE_NAME="XFCE"
elif command -v startplasma-x11 &>/dev/null; then
    DE_CMD="startplasma-x11"
    DE_NAME="KDE Plasma"
elif command -v startkde &>/dev/null; then
    DE_CMD="startkde"
    DE_NAME="KDE"
elif command -v gnome-session &>/dev/null; then
    DE_CMD="gnome-session"
    DE_NAME="GNOME"
elif command -v mate-session &>/dev/null; then
    DE_CMD="mate-session"
    DE_NAME="MATE"
elif command -v cinnamon-session &>/dev/null; then
    DE_CMD="cinnamon-session"
    DE_NAME="Cinnamon"
elif command -v lxsession &>/dev/null; then
    DE_CMD="lxsession"
    DE_NAME="LXDE"
elif command -v startlxqt &>/dev/null; then
    DE_CMD="startlxqt"
    DE_NAME="LXQt"
elif command -v i3 &>/dev/null; then
    DE_CMD="i3"
    DE_NAME="i3wm"
elif command -v openbox-session &>/dev/null; then
    DE_CMD="openbox-session"
    DE_NAME="Openbox"
elif command -v fluxbox &>/dev/null; then
    DE_CMD="fluxbox"
    DE_NAME="Fluxbox"
elif command -v twm &>/dev/null; then
    DE_CMD="twm"
    DE_NAME="TWM (minimal)"
else
    DE_CMD=""
    DE_NAME="NONE"
fi

echo "DE_CMD=$DE_CMD"
echo "DE_NAME=$DE_NAME"
DETECTSCRIPT
    )

    local de_cmd de_name
    de_cmd=$(echo "$de_result" | grep "^DE_CMD=" | cut -d= -f2-)
    de_name=$(echo "$de_result" | grep "^DE_NAME=" | cut -d= -f2-)

    if [[ -z "$de_cmd" || "$de_name" == "NONE" ]]; then
        warn "No desktop environment detected on remote."
        warn "Installing XFCE as lightweight fallback..."
        remote_exec_stdin <<'XFCE_INSTALL'
if command -v apt-get &>/dev/null; then
    sudo apt-get update -qq
    sudo apt-get install -y -qq xfce4 xfce4-goodies dbus-x11
elif command -v dnf &>/dev/null; then
    sudo dnf groupinstall -y "Xfce Desktop"
elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm xfce4 xfce4-goodies dbus-x11
fi
XFCE_INSTALL
        de_cmd="startxfce4"
        de_name="XFCE (freshly installed)"
        ok "XFCE installed as fallback DE."
    else
        ok "Detected: ${de_name}"
    fi

    # Export for use in xstartup
    REMOTE_DE_CMD="$de_cmd"
    REMOTE_DE_NAME="$de_name"

    echo ""
}

# ── Configure VNC password on remote ────────────────────────
configure_vnc_password() {
    info "Configuring VNC password on remote..."

    # TigerVNC uses vncpasswd which reads from stdin with specific format
    local pass_result
    pass_result=$(sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -p "$REMOTE_PORT" "$REMOTE_USER@$REMOTE_HOST" bash -s -- "$VNC_PASS" <<'PASSSCRIPT'
VNC_PW="$1"
mkdir -p "$HOME/.vnc"

# Use tigervncpasswd or vncpasswd
if command -v tigervncpasswd &>/dev/null; then
    PASSCMD="tigervncpasswd"
elif command -v vncpasswd &>/dev/null; then
    PASSCMD="vncpasswd"
else
    echo "PASS_FAIL"
    exit 1
fi

# Set password non-interactively
# Method 1: Try expect-style if possible
printf '%s\n%s\nn\n' "$VNC_PW" "$VNC_PW" | "$PASSCMD" "$HOME/.vnc/passwd" 2>/dev/null

# Verify passwd file exists and has content
if [ -f "$HOME/.vnc/passwd" ] && [ -s "$HOME/.vnc/passwd" ]; then
    chmod 600 "$HOME/.vnc/passwd"
    echo "PASS_OK"
else
    # Method 2: Manual passwd file creation via tigervncpasswd -f
    if echo "$VNC_PW" | "$PASSCMD" -f > "$HOME/.vnc/passwd" 2>/dev/null; then
        chmod 600 "$HOME/.vnc/passwd"
        echo "PASS_OK"
    else
        echo "PASS_FAIL"
    fi
fi
PASSSCRIPT
    )

    if [[ "$pass_result" == *"PASS_OK"* ]]; then
        ok "VNC password configured."
    else
        warn "Could not set VNC password automatically."
        warn "You may be prompted when connecting."
    fi

    echo ""
}

# ── Configure xstartup on remote ────────────────────────────
configure_xstartup() {
    info "Configuring VNC xstartup with ${REMOTE_DE_NAME}..."

    local xstartup_result
    xstartup_result=$(sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -p "$REMOTE_PORT" "$REMOTE_USER@$REMOTE_HOST" bash -s -- "$REMOTE_DE_CMD" <<'XSTARTSCRIPT'
DE_CMD="$1"
XSTARTUP="$HOME/.vnc/xstartup"

mkdir -p "$HOME/.vnc"

# Backup existing xstartup
[ -f "$XSTARTUP" ] && [ ! -f "${XSTARTUP}.vncforward.bak" ] && cp "$XSTARTUP" "${XSTARTUP}.vncforward.bak"

cat > "$XSTARTUP" <<INNEREOF
#!/bin/bash
# xstartup - generated by vncforward
# Desktop: $DE_CMD

# Clean environment
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS

# Set up DBus
if command -v dbus-launch &>/dev/null; then
    eval \$(dbus-launch --sh-syntax)
    export DBUS_SESSION_BUS_ADDRESS
fi

# Set XDG runtime dir
export XDG_RUNTIME_DIR="/run/user/\$(id -u)"
[ ! -d "\$XDG_RUNTIME_DIR" ] && { mkdir -p "\$XDG_RUNTIME_DIR" 2>/dev/null; chmod 700 "\$XDG_RUNTIME_DIR" 2>/dev/null; } || true

# X resources
[ -r "\$HOME/.Xresources" ] && xrdb "\$HOME/.Xresources"

# Start the desktop environment
exec $DE_CMD
INNEREOF

chmod +x "$XSTARTUP"
echo "XSTARTUP_OK"
XSTARTSCRIPT
    )

    if [[ "$xstartup_result" == *"XSTARTUP_OK"* ]]; then
        ok "xstartup configured: exec ${REMOTE_DE_CMD}"
    else
        warn "Could not write xstartup. VNC may start with a bare X session."
    fi

    echo ""
}

# ── Configure VNC security ──────────────────────────────────
configure_vnc_security() {
    info "Configuring VNC security settings on remote..."

    local sec_result
    sec_result=$(remote_exec_stdin <<'SECSCRIPT'
VNC_CONF="$HOME/.vnc/config"

mkdir -p "$HOME/.vnc"

# Backup
[ -f "$VNC_CONF" ] && [ ! -f "${VNC_CONF}.vncforward.bak" ] && cp "$VNC_CONF" "${VNC_CONF}.vncforward.bak"

cat > "$VNC_CONF" <<'CONFEOF'
# TigerVNC config - generated by vncforward
securitytypes=VncAuth,TLSVnc
localhost=no
alwaysshared
CONFEOF

echo "SEC_OK"
SECSCRIPT
    )

    if [[ "$sec_result" == *"SEC_OK"* ]]; then
        ok "VNC security configured."
    else
        warn "Could not write VNC config."
    fi

    echo ""
}

# ── Start VNC session on remote ─────────────────────────────
start_remote_vnc() {
    info "Starting VNC session on remote (display ${VNC_DISPLAY}, ${VNC_RESOLUTION})..."

    # First kill any existing session on this display
    remote_exec "vncserver -kill ${VNC_DISPLAY} 2>/dev/null; sleep 1; true" &>/dev/null

    local start_result
    start_result=$(sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -p "$REMOTE_PORT" "$REMOTE_USER@$REMOTE_HOST" \
        "vncserver ${VNC_DISPLAY} -geometry ${VNC_RESOLUTION} -depth ${VNC_DEPTH} -localhost $(if $USE_TUNNEL; then echo yes; else echo no; fi) 2>&1 && echo VNC_STARTED || echo VNC_FAILED")

    if [[ "$start_result" == *"VNC_STARTED"* ]]; then
        ok "VNC server started on ${VNC_DISPLAY} (port ${VNC_PORT})"
    elif [[ "$start_result" == *"already running"* ]] || [[ "$start_result" == *"already in use"* ]]; then
        warn "VNC display ${VNC_DISPLAY} already in use. Attempting restart..."
        remote_exec "vncserver -kill ${VNC_DISPLAY} 2>/dev/null; sleep 2" &>/dev/null
        start_result=$(sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
            -p "$REMOTE_PORT" "$REMOTE_USER@$REMOTE_HOST" \
            "vncserver ${VNC_DISPLAY} -geometry ${VNC_RESOLUTION} -depth ${VNC_DEPTH} -localhost $(if $USE_TUNNEL; then echo yes; else echo no; fi) 2>&1 && echo VNC_STARTED || echo VNC_FAILED")
        if [[ "$start_result" == *"VNC_STARTED"* ]]; then
            ok "VNC server restarted on ${VNC_DISPLAY}"
        else
            fail "Could not start VNC server."
            $VERBOSE && echo -e "  ${DIM}${start_result}${RESET}"
            die "VNC server failed to start. Check remote logs: ~/.vnc/*.log"
        fi
    else
        fail "VNC server failed to start."
        $VERBOSE && echo -e "  ${DIM}${start_result}${RESET}"
        die "Check remote logs: ~/.vnc/*.log"
    fi

    echo ""
}

# ── Kill remote VNC session ─────────────────────────────────
kill_remote_vnc() {
    info "Killing VNC session ${VNC_DISPLAY} on remote..."

    local kill_result
    kill_result=$(remote_exec "vncserver -kill ${VNC_DISPLAY} 2>&1; echo KILL_DONE")

    if [[ "$kill_result" == *"KILL_DONE"* ]]; then
        ok "VNC session ${VNC_DISPLAY} killed."
    else
        warn "Session may not have been running."
    fi

    # Also clean stale lock/pid files
    remote_exec "rm -f /tmp/.X${VNC_DISPLAY#:}-lock /tmp/.X11-unix/X${VNC_DISPLAY#:} 2>/dev/null; true" &>/dev/null
    ok "Cleaned up stale lock files."

    echo ""
    exit 0
}

# ── Open SSH tunnel ─────────────────────────────────────────
open_tunnel() {
    info "Opening SSH tunnel: localhost:${LOCAL_PORT} → remote:${VNC_PORT}..."

    # Kill any existing tunnel on the local port
    local existing_pid
    existing_pid=$(lsof -ti ":${LOCAL_PORT}" 2>/dev/null || true)
    if [[ -n "$existing_pid" ]]; then
        warn "Port ${LOCAL_PORT} in use (PID ${existing_pid}). Killing..."
        kill "$existing_pid" 2>/dev/null || true
        sleep 1
    fi

    sshpass -p "$REMOTE_PASS" ssh -o StrictHostKeyChecking=no \
        -o ExitOnForwardFailure=yes \
        -o ServerAliveInterval=60 \
        -o ServerAliveCountMax=3 \
        -f -N -L "${LOCAL_PORT}:localhost:${VNC_PORT}" \
        -p "$REMOTE_PORT" "$REMOTE_USER@$REMOTE_HOST"

    # Verify tunnel is up
    sleep 1
    if lsof -ti ":${LOCAL_PORT}" &>/dev/null; then
        ok "SSH tunnel established: localhost:${LOCAL_PORT} → ${REMOTE_HOST}:${VNC_PORT}"
    else
        die "SSH tunnel failed to establish."
    fi

    echo ""
}

# ── Find VNC viewer ─────────────────────────────────────────
find_viewer() {
    for v in xtigervncviewer vncviewer xvnc4viewer; do
        if command -v "$v" &>/dev/null; then
            echo "$v"
            return 0
        fi
    done
    echo ""
    return 1
}

# ── Summary ─────────────────────────────────────────────────
print_summary() {
    echo -e "${BOLD}─── VNC Session Summary ───${RESET}"
    echo ""
    echo -e "  Remote:      ${GREEN}${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PORT}${RESET}"
    echo -e "  VNC Display: ${GREEN}${VNC_DISPLAY} (port ${VNC_PORT})${RESET}"
    echo -e "  Resolution:  ${GREEN}${VNC_RESOLUTION} @ ${VNC_DEPTH}-bit${RESET}"
    echo -e "  Desktop:     ${GREEN}${REMOTE_DE_NAME:-auto}${RESET}"
    if $USE_TUNNEL; then
        echo -e "  Mode:        ${GREEN}SSH Tunnel (localhost:${LOCAL_PORT})${RESET}"
    else
        echo -e "  Mode:        ${YELLOW}Direct (${REMOTE_HOST}:${VNC_PORT})${RESET}"
    fi
    echo ""
    echo -e "  ${DIM}To kill the session later:${RESET}"
    echo -e "  ${DIM}  $(basename "$0") -h ${REMOTE_HOST} -u ${REMOTE_USER} --kill${RESET}"
    echo ""
}

# ── Connect viewer ──────────────────────────────────────────
connect_viewer() {
    print_summary

    if $DRY_RUN; then
        info "Dry run — not connecting."
        if $USE_TUNNEL; then
            echo -e "  Tunnel: ssh -f -N -L ${LOCAL_PORT}:localhost:${VNC_PORT} -p ${REMOTE_PORT} ${REMOTE_USER}@${REMOTE_HOST}"
            echo -e "  Viewer: vncviewer localhost:${LOCAL_PORT}"
        else
            echo -e "  Viewer: vncviewer ${REMOTE_HOST}:${VNC_PORT}"
        fi
        echo ""
        exit 0
    fi

    local viewer
    viewer=$(find_viewer)
    if [[ -z "$viewer" ]]; then
        die "No VNC viewer found. Install: sudo apt install tigervnc-viewer"
    fi

    local target
    if $USE_TUNNEL; then
        target="localhost:${LOCAL_PORT}"
    else
        target="${REMOTE_HOST}:${VNC_PORT}"
    fi

    echo -e "${BOLD}${GREEN}Launching VNC viewer → ${target}${RESET}"
    echo -e "${DIM}(Close the viewer window to disconnect)${RESET}"
    echo ""

    # Write a temporary VNC password file for auto-login
    local tmp_passfile=""
    if [[ -n "$VNC_PASS" ]]; then
        tmp_passfile=$(mktemp /tmp/vncpass.XXXXXX)
        # Try to create a compatible password file
        if command -v tigervncpasswd &>/dev/null; then
            echo "$VNC_PASS" | tigervncpasswd -f > "$tmp_passfile" 2>/dev/null
        elif command -v vncpasswd &>/dev/null; then
            echo "$VNC_PASS" | vncpasswd -f > "$tmp_passfile" 2>/dev/null
        fi
    fi

    # Launch viewer
    if [[ -n "$tmp_passfile" && -s "$tmp_passfile" ]]; then
        "$viewer" -passwd "$tmp_passfile" "$target" 2>/dev/null
        rm -f "$tmp_passfile"
    else
        [[ -n "$tmp_passfile" ]] && rm -f "$tmp_passfile"
        "$viewer" "$target" 2>/dev/null
    fi

    echo ""
    info "VNC viewer closed."

    # Cleanup tunnel
    if $USE_TUNNEL; then
        info "Cleaning up SSH tunnel..."
        local tunnel_pid
        tunnel_pid=$(lsof -ti ":${LOCAL_PORT}" 2>/dev/null || true)
        if [[ -n "$tunnel_pid" ]]; then
            kill "$tunnel_pid" 2>/dev/null || true
            ok "SSH tunnel closed."
        fi
    fi

    echo ""
    echo -e "${DIM}VNC session is still running on remote.${RESET}"
    echo -e "${DIM}To kill it: $(basename "$0") -h ${REMOTE_HOST} -u ${REMOTE_USER} --kill${RESET}"
    echo ""
}

# ── Main ────────────────────────────────────────────────────
main() {
    parse_args "$@"
    banner
    prompt_credentials
    check_local_deps
    test_connection

    # Kill mode
    if $KILL_SESSION; then
        kill_remote_vnc
        exit 0
    fi

    # Viewer-only mode (skip all setup)
    if $VIEWER_ONLY; then
        REMOTE_DE_NAME="(viewer-only, skipped detection)"
        if $USE_TUNNEL; then
            open_tunnel
        fi
        connect_viewer
        exit 0
    fi

    # Full setup flow
    install_remote_vnc
    detect_remote_de
    configure_vnc_password
    configure_xstartup
    configure_vnc_security
    start_remote_vnc

    if $USE_TUNNEL; then
        open_tunnel
    fi

    connect_viewer
}

main "$@"
