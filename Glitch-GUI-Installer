#!/bin/bash

LOG_FILE="/tmp/glitch_installer_setup.log"
RUNTIME_LOG="/tmp/glitch_installer_runtime.log"
DEST="/tmp/glitch_installer.py"
URL="https://raw.githubusercontent.com/GlitchLinux/Glitch-GUI-Installer/refs/heads/main/glitch_installer.py"

# ── Logging helpers ──
log() { echo "[*] $1" | tee -a "$LOG_FILE"; }
ok()  { echo "[+] $1" | tee -a "$LOG_FILE"; }
err() { echo "[!] $1" | tee -a "$LOG_FILE"; }

# ── Cleanup old files ──
cleanup_old() {
    echo "[*] Cleaning old installer files..."

    # Kill any running old installer
    pkill -f "$DEST" 2>/dev/null

    # Remove old files
    rm -f "$DEST" \
          "$LOG_FILE" \
          "$RUNTIME_LOG"

    echo "[+] Cleanup done"
}

# ── Install dependencies ──
install_deps() {
    log "Checking dependencies..."

    local pkgs=(python3-pyqt5 python3-psutil wget x11-xserver-utils xvfb)
    local missing=()

    for pkg in "${pkgs[@]}"; do
        if ! dpkg -s "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        log "Installing: ${missing[*]}"
        apt-get update -qq >> "$LOG_FILE" 2>&1 || {
            err "apt update failed"
            exit 1
        }
        apt-get install -y -qq "${missing[@]}" >> "$LOG_FILE" 2>&1 || {
            err "Dependency installation failed"
            exit 1
        }
        ok "Dependencies installed"
    else
        ok "All dependencies already installed"
    fi
}

# ── Download installer ──
download_installer() {
    log "Downloading installer..."
    wget -q "$URL" -O "$DEST" >> "$LOG_FILE" 2>&1 || {
        err "Download failed"
        exit 1
    }
    chmod +x "$DEST"
    ok "Installer downloaded to $DEST"
}

# ── Detect GUI environment ──
has_display() {
    [[ -n "$DISPLAY" ]]
}

# ── Launch installer ──
launch_installer() {
    log "Preparing to launch installer..."

    if has_display; then
        log "GUI detected (DISPLAY=$DISPLAY)"

        export DISPLAY
        export XAUTHORITY=${XAUTHORITY:-$HOME/.Xauthority}

        if [ "$EUID" -ne 0 ]; then
            log "Allowing root access to X..."
            xhost +SI:localuser:root >/dev/null 2>&1

            log "Launching GUI installer..."
            sudo -E nohup python3 "$DEST" > "$RUNTIME_LOG" 2>&1 &
        else
            log "Launching GUI installer as root..."
            nohup python3 "$DEST" > "$RUNTIME_LOG" 2>&1 &
        fi

    else
        log "No GUI → using Xvfb (headless mode)"

        if [ "$EUID" -ne 0 ]; then
            sudo nohup xvfb-run -a python3 "$DEST" > "$RUNTIME_LOG" 2>&1 &
        else
            nohup xvfb-run -a python3 "$DEST" > "$RUNTIME_LOG" 2>&1 &
        fi
    fi

    ok "Installer started (PID: $!)"
    log "Runtime log: $RUNTIME_LOG"
}

# ── Main ──
main() {
    # Ensure root
    if [ "$EUID" -ne 0 ]; then
        exec sudo bash "$0" "$@"
    fi

    cleanup_old
    install_deps
    download_installer
    launch_installer
}

main "$@"
